# Particle Network
NEXT_PUBLIC_PARTICLE_PROJECT_ID=
NEXT_PUBLIC_PARTICLE_CLIENT_KEY=
NEXT_PUBLIC_PARTICLE_APP_ID=
PARTICLE_SERVER_KEY=

# Magic
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Chain config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DESTINATION_CHAIN_ID=8453
# Modes: transfer_fallback (default) | universal_invoice | universal_7702_transfer
NEXT_PUBLIC_PAYMENT_MODE=transfer_fallback
# NOTE: the values above are the SAFE LOCAL defaults (Base + transfer_fallback). The live PROD demo
# runs NEXT_PUBLIC_PAYMENT_MODE=universal_7702_transfer with Arbitrum One settlement (cross-chain via
# Particle UA, ledger C21); mirror it locally with NEXT_PUBLIC_DESTINATION_CHAIN_ID=42161.
# One-tap checkout (Spec one-tap-checkout): "true" collapses /pay to a single "Pay" after the Trust
# Preview. Default off (unset/false) = the proven two-step flow. Enable only after live-verify.
NEXT_PUBLIC_ONE_TAP_CHECKOUT=false
NEXT_PUBLIC_RECEIPT_EMITTER_ADDRESS=
# SpendPolicy: on-chain enforcement of signed PaymentMandates (Permission Firewall).
# Deploy with: cd contracts && pnpm deploy:spend-policy:base  (or :base-sepolia)
NEXT_PUBLIC_SPEND_POLICY_ADDRESS=
# SpendPolicy on Arbitrum One (Arbitrum-first deployment)
NEXT_PUBLIC_SPEND_POLICY_ADDRESS_ARBITRUM=
NEXT_PUBLIC_ENABLE_DEBUG_PROBES=false
BASE_MAINNET_RPC_URL=
# Public Base RPC used client-side by Magic's EVMExtension in universal_7702_transfer mode
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_ARBITRUM_CHAIN_ID=42161
NEXT_PUBLIC_ARBITRUM_USDC_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831
ARBITRUM_MAINNET_RPC_URL=
NEXT_PUBLIC_ARBITRUM_RECEIPT_EMITTER_ADDRESS=
# Optimism is an experimental, unclaimed settlement probe (zero-balance) for cross-chain routing
# experiments only. NOT part of the live demo (Base + Arbitrum).
NEXT_PUBLIC_OPTIMISM_CHAIN_ID=10
NEXT_PUBLIC_OPTIMISM_USDC_ADDRESS=0x0b2C639c533813f4Aa9D7837CAf62653d097Ff85
OPTIMISM_MAINNET_RPC_URL=
# Public Optimism RPC used client-side by Magic's EVMExtension in universal_7702_transfer mode
NEXT_PUBLIC_OPTIMISM_RPC_URL=https://mainnet.optimism.io
# The ReceiptEmitter owner = the key that signs InvoicePaid attestations. It MUST be distinct from
# the merchant payee (attestor != payee). In this deploy it is the relayer key (R26 done); a
# production deploy should use a dedicated attestor key distinct from both merchant and relayer.
# See risk-register R26 + contracts/scripts/transfer-receipt-emitter-owner.ts.
RECEIPT_EMITTER_OWNER_PRIVATE_KEY=
# Optional: dedicated gas-paying key for /api/mandates/charge so the relayer signer is separable
# from the proof-owner key above. If unset, the route falls back to RECEIPT_EMITTER_OWNER_PRIVATE_KEY.
RELAYER_PRIVATE_KEY=
# Relayer gas guard for the public charge route (caps gas-spending sends per rolling window).
RELAYER_MAX_CHARGES_PER_WINDOW=30
RELAYER_CHARGE_WINDOW_MS=600000
ADMIN_CREATE_TOKEN=

# ZeroDev (stretch)
NEXT_PUBLIC_ZERODEV_PROJECT_ID=

# Sponsored EIP-7702 delegation (Spec `sponsored-delegation`): when "true", a first-time payer's
# one-time per-chain delegation is submitted by the RELAYER (relayer pays gas) so the payer needs
# ZERO native gas. Default OFF (self-paid delegation, unchanged). Flip ON only after a live spike
# verifies a relayer-paid delegation on-chain. The relayer (RELAYER_PRIVATE_KEY) must be funded on
# each sponsored chain.
NEXT_PUBLIC_SPONSORED_DELEGATION=false
# Optional: cap relayer-paid delegations per rolling window (default 20; window = RELAYER_CHARGE_WINDOW_MS).
# RELAYER_MAX_DELEGATIONS_PER_WINDOW=20

# Relayer allowlists (R16 hardening) for the PUBLIC relayer routes /api/mandates/charge and
# /api/delegate/sponsor. Comma-separated addresses; the literal "*" opens the route to ANY address.
# Unset/blank = the demo addresses only. These bound the relayer's GAS (payer funds are already
# bound by the signed mandate + on-chain caps). With the defaults, /api/mandates/charge only serves
# the funded demo payer -> demo merchant; set CHARGE_PAYER_ALLOWLIST=* to let any logged-in wallet
# drive the interactive /firewall + /agent charge. Walletless /try (/api/demo/firewall-block) is a
# separate route and is unaffected.
CHARGE_MERCHANT_ALLOWLIST=
CHARGE_PAYER_ALLOWLIST=
SPONSOR_PAYER_ALLOWLIST=
